# ─────────────────────────────────────────────
# pm_as_ofi 推荐模板（当前 pair_arb 验证主线）
# 主线策略：pair_arb
# 收益验证市场：btc-updown-15m（5m 仅用于机制冒烟）
# 说明：
# 1. 这是推荐模板，不是代码内部 fallback 默认值。
# 2. 代码 fallback 仍偏保守；验证请显式配置 PM_STRATEGY=pair_arb。
# 3. 本模板默认先 dry-run，确认日志正常后再切到 live。
# ─────────────────────────────────────────────

# ═══ 市场选择 ═══
# 最高优先级：直接指定当前轮次/轮转前缀。
POLYMARKET_MARKET_SLUG="btc-updown-15m"
# 如需强制覆盖 Binance 合约映射，可手动指定；pair_arb 主线通常不需要。
# PM_BINANCE_SYMBOL_OVERRIDE="BTCUSDT"

# ═══ 连接端点 ═══
# Polymarket 市场/用户 WS 根地址；程序内部会再拼接子路径。
POLYMARKET_WS_BASE_URL="wss://ws-subscriptions-clob.polymarket.com/ws"
# Polymarket CLOB REST 根地址。
POLYMARKET_REST_URL="https://clob.polymarket.com"

# ═══ 认证（实盘必填） ═══
# 交易私钥；dry-run 可留空，live 必填。
POLYMARKET_PRIVATE_KEY=""
# 对应的资金地址 / 代理地址；live 必填。
POLYMARKET_FUNDER_ADDRESS=""

# 可选：CLOB/User WS API 凭证。
# 留空时程序会尝试派生；若派生失败，再显式填写。
# POLYMARKET_API_KEY=""
# POLYMARKET_API_SECRET=""
# POLYMARKET_API_PASSPHRASE=""

# Claim / merge（Safe 路径）需要 Builder 凭证。
# 若不开 auto-claim 或不用 safe merge，可先不填。
# POLYMARKET_BUILDER_API_KEY=""
# POLYMARKET_BUILDER_SECRET=""
# POLYMARKET_BUILDER_PASSPHRASE=""
# Relayer 默认值通常无需改动。
# POLYMARKET_RELAYER_URL="https://relayer-v2.polymarket.com"

# ═══ 运行模式 ═══
# true = 演习，不真实下单；首次验证建议保持 true。
PM_DRY_RUN=true
# 新市场开始后允许入场的窗口；太短容易错过早期流动性。
PM_ENTRY_GRACE_SECONDS=30
# 市场 WS 建连超时。
PM_WS_CONNECT_TIMEOUT_MS=6000
# 连续 WS 故障达到阈值后，提前放弃当前轮，等待下一轮。
PM_WS_DEGRADE_MAX_FAILURES=12
# Gamma 市场解析单次超时。
PM_RESOLVE_TIMEOUT_MS=4000
# Gamma 市场解析重试次数。
PM_RESOLVE_RETRY_ATTEMPTS=4
# REST 对账周期；不要太低，避免无意义噪音。
PM_RECONCILE_INTERVAL_SECS=30
# Coordinator 在无行情时的风控心跳。
PM_COORD_WATCHDOG_MS=500
# 策略/库存指标日志周期。
PM_STRATEGY_METRICS_LOG_SECS=15

# ═══ 当前推荐主线：pair_arb ═══
# 当前推荐验证主策略。不要依赖代码 fallback。
PM_STRATEGY=pair_arb
# 单槽位基础下单份额；当前保守 live 基线为 5 shares。
PM_BID_SIZE=5.0
# 盘中净仓硬上限；pair_arb 三段库存基线（5/10/15）。
PM_MAX_NET_DIFF=15.0
# 组合成本目标线（pair_arb 核心参数）。
PM_PAIR_TARGET=0.98

# 基础 tick 粒度。
PM_TICK_SIZE=0.01
# post-only 基础安全垫，防止 quote 撞穿盘口。
PM_POST_ONLY_SAFETY_TICKS=2.0
# 点差很小的时候，额外扩大安全垫的触发线。
PM_POST_ONLY_TIGHT_SPREAD_TICKS=3.0
# 进入紧价差状态后，再额外退让的 ticks。
PM_POST_ONLY_EXTRA_TIGHT_TICKS=1.0
# 触发重报价的最小价差；当前已提高到 0.02 以减少抖动。
PM_REPRICE_THRESHOLD=0.020
# maker provide 防抖；抑制撤挂风暴。
PM_DEBOUNCE_MS=700
# 单侧盘口超过该 TTL 视为 stale。
PM_STALE_TTL_MS=3000
# toxic 恢复后的额外冷却，避免刚恢复就反复撤挂。
PM_TOXIC_RECOVERY_HOLD_MS=1200

# pair_arb 的 A-S 库存偏置参数（当前主线启用）
# 推荐：低 skew + 三段库存（避免一笔 fill 就把偏置打满）
PM_AS_SKEW_FACTOR=0.06
# 推荐：仅在后半段库存叠加时间衰减
PM_AS_TIME_DECAY_K=1.0
# 主仓侧 avg-cost cap（pair_arb）
# 5 <= |net_diff| < 10 时使用 tier_1；|net_diff| >= 10 时使用 tier_2。
PM_PAIR_ARB_TIER_1_MULT=0.70
PM_PAIR_ARB_TIER_2_MULT=0.30

# ═══ GLFT（仅 glft_mm challenger 使用） ═══
# inventory shift 风险厌恶系数。
PM_GLFT_GAMMA=0.10
# 终端惩罚系数；V1 推荐与 gamma 相同。
PM_GLFT_XI=0.10
# OFI 对 reservation price 的偏移强度。
PM_GLFT_OFI_ALPHA=0.30
# OFI 对价差扩张的非线性乘子。
PM_GLFT_OFI_SPREAD_BETA=1.00
# GLFT 每侧最小 half spread（ticks）；用于抑制快盘窄价差被连续吃单。
PM_MIN_HALF_SPREAD_TICKS=5.0
# 强度拟合统计窗口。
PM_GLFT_INTENSITY_WINDOW_SECS=30
# 强度拟合重估周期。
PM_GLFT_REFIT_SECS=10

# ═══ OFI（当前 pair_arb 验证基线） ═══
# OFI 滑窗长度。
PM_OFI_WINDOW_MS=3000
# 冷启动阈值；tail-quantile 自适应尚未 warm-up 前使用。
PM_OFI_TOXICITY_THRESHOLD=300.0
# 是否启用 regime-aware 自适应 OFI（Q99 enter / Q95 exit）。
PM_OFI_ADAPTIVE=true
# 旧 mean+sigma OFI 的兼容参数；当前 regime-normalized 模式不使用。
PM_OFI_ADAPTIVE_K=4.2
# regime baseline 下限护栏，避免在冷清期过敏。
PM_OFI_ADAPTIVE_MIN=120.0
# regime baseline 上限护栏；命中上限会打印 saturated 日志。
PM_OFI_ADAPTIVE_MAX=1800.0
# 旧 rise-cap OFI 的兼容参数；当前 regime-normalized 模式不使用。
PM_OFI_ADAPTIVE_RISE_CAP_PCT=0.20
# 自适应样本窗口；用于 rolling Q50/Q99/Q95。
PM_OFI_ADAPTIVE_WINDOW=200
# 进入 toxic 的比例门槛。
PM_OFI_RATIO_ENTER=0.70
# 退出 toxic 的比例门槛；应低于 enter。
PM_OFI_RATIO_EXIT=0.40
# OFI 心跳周期。
PM_OFI_HEARTBEAT_MS=200
# 毒性退出滞回比例。
PM_OFI_EXIT_RATIO=0.85
# 单次 toxic 最短持续时间。
PM_OFI_MIN_TOXIC_MS=800

# ═══ Endgame ═══
# 当前 pair_arb 仅接入最小 SoftClose：最后 45s 阻断 risk-increasing buy。
PM_ENDGAME_SOFT_CLOSE_SECS=45
PM_ENDGAME_HARD_CLOSE_SECS=30
PM_ENDGAME_FREEZE_SECS=2

# ═══ Hedge / marketable-BUY safety valve ═══
# 以下参数当前不属于 pair_arb 主路径，保留仅为兼容旧路径/未来增强。
# PM_MAX_PORTFOLIO_COST=1.02
# PM_HEDGE_DEBOUNCE_MS=100
# PM_MIN_HEDGE_SIZE=0.0
# PM_HEDGE_ROUND_UP=false
# PM_HEDGE_MIN_MARKETABLE_NOTIONAL=0.0
# PM_HEDGE_MIN_MARKETABLE_MAX_EXTRA=0.5
# PM_HEDGE_MIN_MARKETABLE_MAX_EXTRA_PCT=0.15
# PM_ENDGAME_MAKER_REPAIR_MIN_SECS=8
# PM_ENDGAME_EDGE_KEEP_MULT=1.5
# PM_ENDGAME_EDGE_EXIT_MULT=1.25

# 若不配置，系统将尝试从盘口自动探测最小订单份额。
# PM_MIN_ORDER_SIZE=5.0
# 全局 marketable-BUY 名义预检；0 = 关闭。
PM_MIN_MARKETABLE_NOTIONAL_FLOOR=0.0
# 是否从拒单里自动学习最小名义门槛。
PM_MIN_MARKETABLE_AUTO_DETECT=false
# 命中最小名义拒单后的侧边冷却。
PM_MIN_MARKETABLE_COOLDOWN_MS=10000

# ═══ recycle / merge ═══
# 启用资金回收。
PM_RECYCLE_ENABLED=true
# false = Hedge + Provide 拒单都可触发；true = 仅 Hedge。
PM_RECYCLE_ONLY_HEDGE=false
# 触发回收所需的拒单次数。
PM_RECYCLE_TRIGGER_REJECTS=2
# 拒单统计窗口。
PM_RECYCLE_TRIGGER_WINDOW_SECS=90
# 是否启用低水位主动探测。
PM_RECYCLE_PROACTIVE=true
# 主动探测轮询周期。
PM_RECYCLE_POLL_SECS=5
# 两次回收之间的最小间隔。
PM_RECYCLE_COOLDOWN_SECS=120
# 单轮最多 merge 次数。
PM_RECYCLE_MAX_MERGES_PER_ROUND=2
# 低水位门槛。
PM_RECYCLE_LOW_WATER_USDC=6.0
# 回收目标可用余额。
PM_RECYCLE_TARGET_FREE_USDC=18.0
# 单次最小回收批量。
PM_RECYCLE_MIN_BATCH_USDC=10.0
# 单次最大回收批量。
PM_RECYCLE_MAX_BATCH_USDC=30.0
# 资金缺口放大倍率。
PM_RECYCLE_SHORTFALL_MULT=1.2
# 低于该金额时不执行回收。
PM_RECYCLE_MIN_EXECUTABLE_USDC=5.0
# 余额缓存 TTL。
PM_BALANCE_CACHE_TTL_MS=2000

# ═══ Claim（回合 SLA） ═══
# 是否输出 claim 监控日志。
PM_CLAIM_MONITOR=true
# 是否启用自动 claim。
PM_AUTO_CLAIM=true
# true = 只演练不真正 claim；global dry-run=true 时也会被强制视为 dry-run。
PM_AUTO_CLAIM_DRY_RUN=false
# 单个可领 condition 的最小价值。
PM_AUTO_CLAIM_MIN_VALUE=0
# 单次处理的 condition 上限。
PM_AUTO_CLAIM_MAX_CONDITIONS=5
# 常规 claim 最小间隔。
PM_AUTO_CLAIM_INTERVAL_SECONDS=300
# 每轮结束后的 claim SLA 窗口。
PM_AUTO_CLAIM_ROUND_WINDOW_SECS=30
# 回合 claim 重试模式。
PM_AUTO_CLAIM_ROUND_RETRY_MODE=exponential
# 先 ended market 再 global fallback。
PM_AUTO_CLAIM_ROUND_SCOPE=ended_then_global
# 回合 claim 重试节奏。
PM_AUTO_CLAIM_ROUND_RETRY_SCHEDULE=0,2,5,9,14,20,27
# 是否等待 relayer confirm。
PM_AUTO_CLAIM_WAIT_CONFIRM=false
# claim confirm 等待超时。
PM_AUTO_CLAIM_WAIT_TIMEOUT_SECONDS=20
# SAFE 模式签名类型；auto-claim / merge 常用。
PM_SIGNATURE_TYPE=2

# ═══ 非主线策略参数（仅切换策略时再启用）═══
# 以下参数当前主线 pair_arb 不使用，保留仅为兼容其它内置策略。
# PM_OPEN_PAIR_BAND=0.99
# PM_DIP_BUY_MAX_ENTRY_PRICE=0.20
# PM_BID_PCT=0.02
# PM_NET_DIFF_PCT=0.10

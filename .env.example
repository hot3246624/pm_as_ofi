# ─────────────────────────────────────────────
# Polymarket V2 Maker-Only Engine
# $100 实盘测试配置模板
# ─────────────────────────────────────────────

# ═══ 市场选择 ═══
# 方式 A：直接给前缀/完整 slug（优先级最高）
# 前缀模式（自动轮转）: btc-updown-5m / btc-updown-15m / btc-updown-1h / btc-updown-4h / btc-updown-1d
# 固定模式（单场）: 完整 slug 含时间戳后缀
POLYMARKET_MARKET_SLUG="btc-updown-5m"
# POLYMARKET_MARKET_PREFIX="btc-updown-1h"

# 方式 B：按 symbol + timeframe 自动拼接为 "<symbol>-updown-<timeframe>"
# 未设置 POLYMARKET_MARKET_SLUG/PREFIX 时生效
# POLYMARKET_MARKET_SYMBOL="btc"      # 支持: btc / eth / xrp / sol
# POLYMARKET_MARKET_TIMEFRAME="5m"    # 支持: 1m / 5m / 15m / 30m / 1h / 4h / 1d

# ═══ 连接 ═══
POLYMARKET_WS_BASE_URL="wss://ws-subscriptions-clob.polymarket.com/ws"
POLYMARKET_REST_URL="https://clob.polymarket.com"

# ═══ 认证（实盘必填） ═══
POLYMARKET_PRIVATE_KEY=""
POLYMARKET_FUNDER_ADDRESS=""

# 可选（留空则自动从 PRIVATE_KEY 派生）
# 注意：这里是 CLOB/User WS 的 API 凭证，不是 Builder API 凭证
# POLYMARKET_API_KEY=""
# POLYMARKET_API_SECRET=""
# POLYMARKET_API_PASSPHRASE=""

# ═══ Claim（可选） ═══
# 监控可领取收益（默认开）
PM_CLAIM_MONITOR=true
# 自动领取（默认关）
PM_AUTO_CLAIM=false
PM_AUTO_CLAIM_DRY_RUN=false
PM_AUTO_CLAIM_MIN_VALUE=0
PM_AUTO_CLAIM_MAX_CONDITIONS=5
PM_AUTO_CLAIM_INTERVAL_SECONDS=300
# Safe 自动领取：是否等待 relayer confirm（默认不等待，避免阻塞开盘）
PM_AUTO_CLAIM_WAIT_CONFIRM=false
PM_AUTO_CLAIM_WAIT_TIMEOUT_SECONDS=20
# Safe 自动领取需要 Builder 凭证（Relayer）
# POLYMARKET_BUILDER_API_KEY=""
# POLYMARKET_BUILDER_SECRET=""
# POLYMARKET_BUILDER_PASSPHRASE=""
# Relayer 地址（默认主网）
# POLYMARKET_RELAYER_URL="https://relayer-v2.polymarket.com"

# ═══ 运行模式 ═══
PM_DRY_RUN=true
PM_ENTRY_GRACE_SECONDS=30
PM_WS_CONNECT_TIMEOUT_MS=6000   # Market WS 连接超时（毫秒），失败更快重连
PM_RESOLVE_TIMEOUT_MS=4000      # Gamma 市场解析请求超时（毫秒）
PM_RESOLVE_RETRY_ATTEMPTS=4     # 每轮市场解析重试次数（指数退避）

# ═══ 策略核心 ═══
PM_PAIR_TARGET=0.985          # 保守让利，每对锁利 $0.015
PM_BID_SIZE=5.0               # 提供单规模上限（实盘会被动态资金上限进一步约束）
# PM_MIN_ORDER_SIZE=5.0        # 留空=自动探测；设置后固定覆盖自动探测
PM_MIN_HEDGE_SIZE=0.0         # 对冲触发最小阈值（0=禁用）
PM_HEDGE_ROUND_UP=false       # 对冲不足最小订单时是否向上取整
PM_TICK_SIZE=0.01              # Polymarket 最小精度
PM_POST_ONLY_SAFETY_TICKS=2.0  # Post-only 保护边际（tick）
PM_POST_ONLY_TIGHT_SPREAD_TICKS=3.0 # 价差<=该 tick 时启用额外边际
PM_POST_ONLY_EXTRA_TIGHT_TICKS=1.0   # 紧价差额外边际（tick）
PM_REPRICE_THRESHOLD=0.010    # 新基线：1 分钱漂移才重报价（旧基线常见为 2 分）
PM_DEBOUNCE_MS=500            # 新基线：500ms 防抖（旧基线常见为 1000ms）
PM_HEDGE_DEBOUNCE_MS=100      # 对冲侧更短防抖
PM_HEDGE_MIN_MARKETABLE_NOTIONAL=0.0 # 可选：仅对冲启用的 marketable-BUY 最小金额兜底（0=关闭）
PM_HEDGE_MIN_MARKETABLE_MAX_EXTRA=0.5 # 触发兜底时，单次最多额外加仓（shares）
PM_HEDGE_MIN_MARKETABLE_MAX_EXTRA_PCT=0.15 # 触发兜底时，最多额外比例（相对原对冲量）
PM_RECONCILE_INTERVAL_SECS=30 # 订单对账周期（秒）
PM_COORD_WATCHDOG_MS=500      # Coordinator 风控看门狗心跳（无行情也会触发 stale/toxic 检查）
PM_AS_SKEW_FACTOR=0.03        # A-S 惩罚系数 (0.03=稳健库存厌恶，0.00=纯正激进网格摊薄)
PM_TOXIC_RECOVERY_HOLD_MS=1200 # 毒性恢复后冷却，防止撤挂抖动

# ═══ 风控（$100 资金） ═══
PM_MAX_NET_DIFF=10.0          # 净仓差上限（实盘会被动态资金上限进一步约束）
PM_MAX_PORTFOLIO_COST=1.02    # 组合成本上限
PM_MAX_LOSS_PCT=0.02          # 最大可接受亏损比例（2%）
PM_MAX_SIDE_SHARES=50.0       # 单侧总持仓上限（同时受 PM_MAX_POS_PCT 动态约束）

# ═══ OFI 毒性检测 ═══
PM_OFI_WINDOW_MS=3000         # 3 秒滑窗
PM_OFI_TOXICITY_THRESHOLD=300.0 # 基准阈值（adaptive=true 时作为初始回退值）
PM_OFI_ADAPTIVE=true          # 建议开启：阈值随波动自适应，避免“长期锁定 300”
PM_OFI_ADAPTIVE_K=3.0         # mean + k*sigma
PM_OFI_ADAPTIVE_MIN=120.0     # 自适应阈值下限
PM_OFI_ADAPTIVE_MAX=0.0       # 自适应阈值硬上限（0=关闭硬上限，允许随市场抬升）
PM_OFI_ADAPTIVE_RISE_CAP_PCT=0.20 # 单次心跳阈值最大上升比例（0=关闭；防止阈值瞬时抬升导致误恢复）
PM_OFI_ADAPTIVE_WINDOW=200    # 滚动样本窗口
PM_OFI_RATIO_ENTER=0.45       # 毒性进入比例门槛: |buy-sell|/(buy+sell)
PM_OFI_RATIO_EXIT=0.30        # 毒性退出比例门槛（应 <= enter）
PM_OFI_HEARTBEAT_MS=200       # 200ms 强制刷新
PM_OFI_EXIT_RATIO=0.85        # 毒性退出滞回阈值比例（越小越不易抖动）
PM_OFI_MIN_TOXIC_MS=800       # 单次毒性最短保持时间

# ═══ 动态资金管理 (百分比定额) ═══
PM_BID_PCT=0.02               # 每次挂单占比余额上限 (默认2%)
PM_NET_DIFF_PCT=0.10          # 净头寸差异上限占比 (默认10%)
PM_MAX_POS_PCT=0.70           # 总仓位占比上限 (建议 0.6~0.9)
PM_DYNAMIC_GROSS_REFRESH_SECS=10 # 轮中动态刷新 max_side_shares 的周期（秒）

# ═══ 资金回收（余额压力下批量 merge） ═══
PM_RECYCLE_ENABLED=true               # 开启余额驱动回收器（仅实盘）
PM_RECYCLE_ONLY_HEDGE=true            # 仅统计 Hedge 的余额拒单触发回收
PM_RECYCLE_TRIGGER_REJECTS=2          # 触发阈值：窗口内余额拒单次数
PM_RECYCLE_TRIGGER_WINDOW_SECS=90     # 触发窗口（秒）
PM_RECYCLE_PROACTIVE=true             # 主动 headroom 探测（无需先出现拒单）
PM_RECYCLE_POLL_SECS=5                # 主动探测周期（秒）
PM_RECYCLE_COOLDOWN_SECS=120          # 两次回收最小间隔（秒）
PM_RECYCLE_MAX_MERGES_PER_ROUND=2     # 单轮市场最多 merge 次数
PM_RECYCLE_LOW_WATER_USDC=6.0         # 低水位：低于该余额才执行回收
PM_RECYCLE_TARGET_FREE_USDC=18.0      # 回收目标余额（高水位）
PM_RECYCLE_MIN_BATCH_USDC=10.0        # 单次最小回收金额（USDC）
PM_RECYCLE_MAX_BATCH_USDC=30.0        # 单次最大回收金额（USDC）
PM_RECYCLE_SHORTFALL_MULT=1.2         # 缺口乘数（>1 代表批处理，避免频繁小额 merge）
PM_RECYCLE_MIN_EXECUTABLE_USDC=5.0    # 小于该金额则跳过（避免碎片回收）
PM_BALANCE_CACHE_TTL_MS=2000          # Executor 余额缓存 TTL（毫秒）
